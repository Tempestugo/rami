# LLM Configuration
# Set to 'true' to use the mock judge for development (no API calls needed)
VITE_USE_MOCK_LLM=true

# Ollama local configuration (for running Qwen locally)
VITE_OLLAMA_URL=http://localhost:11434

# Hugging Face Inference API (free tier) for Qwen
# Get your token from https://huggingface.co/settings/tokens
VITE_HF_TOKEN=your_hugging_face_token_here
VITE_HF_MODEL=Qwen/Qwen2.5-1.5B-Instruct
